<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%-title %></title>
  </head>
  <body>


    <h1 class="header"><%= heading %></h1>
    <form method="post" class="floating-area">
      <div class="form-group g1">
        <label for="text">Forespørsler</label>
        <br />
        <input type="text" name="requests" />
      </div>

      <button
        type="submit"
        style="margin-top: 20px; position: relative; z-index: 1000"
      >
        Submit
      </button>
      
      
    </form>

    <div>
      <h2>Sendte spørsmål</h2>
      <% if (messages && messages.length > 0) { %>
        <ul>
          <% messages.forEach(message => { %>
            <li>
              <p><strong>Melding:</strong> <%= message.question_text %></p>
            </li>
          <% }); %>
        </ul>
      <% } else { %>
        <p>Ingen spørsmål sendt ennå.</p>
      <% } %>
    </div>
  </body>
</html>
