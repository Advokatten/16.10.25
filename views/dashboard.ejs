<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%-title %></title>
  </head>
  <body class="dashboard-header">
   
    <div>
      <h1 class="dashboard-header"><%= heading %></h1>
    </div>
    <div> 
      <form  method="post" class="dashboard-form">
       <div class="dashboard-form">
        <label for="text">Spørsmål</label>
        <br />
        <input type="text" name="question_text" />
       </div>

       <button
        type="submit"
        style="margin-top: 20px; position: relative; z-index: 1000"
       >
        Submit
        </button>
     </form>
   </div>
   

    <div class="dashboard-messages-sendt">
      <h2 class="dashboard-h2">Sendte spørsmål</h2>
      <% if (messages && messages.length > 0) { %>
        <ul>
          <% messages.forEach(message => { %>
            <li>
              <p><strong>Melding:</strong> <%= message.question_text %></p>
            </li>
          <% }); %>
        </ul>
      <% } else { %>
        <p>Ingen spørsmål sendt ennå.</p>
      <% } %>
    </div>
  </body>
</html>
